{% macro render_naming_examples(language) -%}
#### Naming Examples - {{ language | capitalize }}

{% if language == 'python' -%}
**Good naming:**
```python
# Functions and variables
def calculate_user_balance(user_id: int) -> float:
    """Calculate total balance for a user."""
    active_accounts = get_user_accounts(user_id)
    total_balance = sum(account.balance for account in active_accounts)
    return total_balance

# Classes
class UserService:
    """Service for user operations."""
    
    def __init__(self, database: Database) -> None:
        self._database = database
    
    def get_user_by_id(self, user_id: int) -> User | None:
        """Retrieve user by ID."""
        return self._database.query(User).filter(User.id == user_id).first()

# Private methods
def _validate_email(email: str) -> bool:
    """Internal validation helper."""
    return "@" in email

# Database models
class UserAccount(Base):
    __tablename__ = "user_accounts"
    
    id: int = Column(Integer, primary_key=True)
    email: str = Column(String, unique=True)
    is_active: bool = Column(Boolean, default=True)

# Configuration (not constants)
from pydantic_settings import BaseSettings

class Settings(BaseSettings):
    database_url: str
    api_timeout: int = 30
```

**Avoid:**
```python
# ❌ Unclear naming
def calc(uid):  # too short
    return data

# ❌ Constants at module level (❌ NOT ALLOWED)
MAX_USERS = 100  # Should be in config

# ❌ Mixed conventions
class user_service:  # should be UserService
    def GetUsers(self):  # should be get_users
        pass

# ❌ Overly abbreviated
def get_usr_acct(uid: int):  # should be get_user_account
    pass
```

{% elif language == 'typescript' -%}
**Good naming:**
```typescript
// Functions and variables
function calculateUserBalance(userId: number): number {
  const activeAccounts = getUserAccounts(userId);
  const totalBalance = activeAccounts.reduce((sum, account) => sum + account.balance, 0);
  return totalBalance;
}

// Classes and interfaces
interface IUserService {
  getUserById(userId: number): Promise<User | null>;
  createUser(data: CreateUserRequest): Promise<User>;
}

class UserService implements IUserService {
  private database: Database;

  constructor(database: Database) {
    this.database = database;
  }

  async getUserById(userId: number): Promise<User | null> {
    return this.database.users.findById(userId);
  }
}

// Types and enums
type UserRole = 'admin' | 'user' | 'guest';

enum UserStatus {
  Active = 'active',
  Inactive = 'inactive',
  Suspended = 'suspended',
}

// Constants (module-level for config)
const API_TIMEOUT = 30000;  // milliseconds
const MAX_RETRIES = 3;

// React component
function UserProfile({ userId }: { userId: number }): JSX.Element {
  const [user, setUser] = useState<User | null>(null);
  const isLoadingUser = user === null;

  return <div>{isLoadingUser ? 'Loading...' : user?.name}</div>;
}

// Custom hook
function useAuth(): { user: User | null; logout: () => void } {
  const [user, setUser] = useState<User | null>(null);

  const logout = (): void => {
    setUser(null);
  };

  return { user, logout };
}

// Database schema (snake_case)
interface UserAccount {
  id: number;
  user_id: number;
  email: string;
  is_active: boolean;
}
```

**Avoid:**
```typescript
// ❌ Unclear naming
function calc(uid: any): any {
  return data;
}

// ❌ Mixed conventions
class User_Service {  // should be UserService
  public GetUsers() {  // should be getUsers
    return [];
  }
}

// ❌ Non-standard constants
const userMaxCount = 100;  // should be USER_MAX_COUNT or MAX_USER_COUNT

// ❌ Overly abbreviated
function getUserAcc(uid: number): Account {  // should be getUserAccount
  return db.findAcct(uid);
}
```

