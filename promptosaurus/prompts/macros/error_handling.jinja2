{% if language == 'python' and pattern_name == 'exception_hierarchy' -%}
**Exception Hierarchies - Python**

Define custom exception base class:
```python
class AppError(Exception):
    """Base exception for all application errors."""
    pass

class ValidationError(AppError):
    """Raised when input validation fails."""
    pass

class NotFoundError(AppError):
    """Raised when requested resource is not found."""
    pass

class PermissionError(AppError):
    """Raised when user lacks required permissions."""
    pass

class ExternalServiceError(AppError):
    """Raised when external service call fails."""
    pass
```

Use in code:
```python
def get_user(user_id: int) -> User:
    if user_id <= 0:
        raise ValidationError(f"Invalid user_id: {user_id}")
    
    user = database.find_user(user_id)
    if user is None:
        raise NotFoundError(f"User {user_id} not found")
    
    return user

def call_external_api() -> dict:
    try:
        response = requests.get(EXTERNAL_API_URL, timeout=5)
    except requests.RequestException as e:
        raise ExternalServiceError(f"API call failed: {e}") from e
```

{% elif language == 'python' and pattern_name == 'context_preservation' -%}
**Context Preservation - Python**

Preserve error context using `from e`:
```python
def process_order(order_id: int) -> Order:
    try:
        # Attempt to fetch order
        order = database.get_order(order_id)
    except DatabaseError as e:
        # Preserve original error in exception chain
        raise OrderProcessingError(
            f"Failed to fetch order {order_id}"
        ) from e
    
    try:
        # Attempt to validate
        order.validate()
    except ValidationError as e:
        # Add context about what was being validated
        raise OrderProcessingError(
            f"Order {order_id} validation failed: {e}"
        ) from e
    
    return order
```

Check full error chain:
```python
try:
    process_order(123)
except OrderProcessingError as e:
    # Access original cause
    root_cause = e.__cause__
    logger.error(f"Processing failed: {e}, root cause: {root_cause}")
```

{% elif language == 'typescript' and pattern_name == 'typed_errors' -%}
**Typed Errors - TypeScript**

Define error types:
```typescript
// Custom error class
class AppError extends Error {
  constructor(
    message: string,
    public code: string,
    public statusCode: number = 500,
  ) {
    super(message);
    this.name = 'AppError';
  }
}

class ValidationError extends AppError {
  constructor(message: string) {
    super(message, 'VALIDATION_ERROR', 400);
    this.name = 'ValidationError';
  }
}

class NotFoundError extends AppError {
  constructor(resource: string, id: unknown) {
    super(`${resource} not found: ${id}`, 'NOT_FOUND', 404);
    this.name = 'NotFoundError';
  }
}

// Use union types for results
type Result<T, E = Error> = 
  | { ok: true; value: T }
  | { ok: false; error: E };

async function getUser(userId: number): Promise<Result<User, AppError>> {
  if (userId <= 0) {
    return {
      ok: false,
      error: new ValidationError('Invalid user ID'),
    };
  }

  try {
    const user = await database.getUser(userId);
    if (!user) {
      return {
        ok: false,
        error: new NotFoundError('User', userId),
      };
    }
    return { ok: true, value: user };
  } catch (err) {
    return {
      ok: false,
      error: new AppError('Database error', 'DB_ERROR', 500),
    };
  }
}

// Use with pattern matching
const result = await getUser(1);
if (result.ok) {
  console.log(result.value.name);
} else {
  logger.error(`Error: ${result.error.code} - ${result.error.message}`);
}
```

{% elif language == 'python' and pattern_name == 'logging_errors' -%}
**Logging Errors - Python**

Always log errors at the boundary:
```python
import logging

logger = logging.getLogger(__name__)

def fetch_user_data(user_id: int) -> User | None:
    try:
        return database.get_user(user_id)
    except DatabaseError as e:
        # Log at ERROR level with full context
        logger.error(
            "Failed to fetch user",
            exc_info=True,
            extra={
                "user_id": user_id,
                "operation": "fetch_user_data",
            },
        )
        # Return safe default or re-raise
        return None

def api_endpoint_handler(request: Request) -> Response:
    try:
        user_id = request.params.get("user_id")
        user = fetch_user_data(user_id)
        if user is None:
            logger.warning(f"User not found: {user_id}")
            return Response(status=404, body="User not found")
        return Response(status=200, body=user.to_dict())
    except ValidationError as e:
        logger.warning(f"Invalid input: {e}")
        return Response(status=400, body=str(e))
    except Exception as e:
        logger.exception("Unexpected error in handler")
        return Response(status=500, body="Internal server error")
```

{% elif language == 'typescript' and pattern_name == 'async_error_handling' -%}
**Async Error Handling - TypeScript**

```typescript
// Always catch promise errors
async function processUser(userId: number): Promise<void> {
  try {
    const user = await fetchUser(userId);
    await validateUser(user);
    await saveUser(user);
  } catch (error) {
    if (error instanceof ValidationError) {
      logger.warn(`Validation failed: ${error.message}`);
    } else if (error instanceof NotFoundError) {
      logger.warn(`User not found: ${userId}`);
    } else {
      logger.error(`Unexpected error: ${error}`);
      throw error;  // Re-throw unknown errors
    }
  }
}

// Handle fire-and-forget with explicit comment
function logEventAsync(event: Event): void {
  // Intentionally not awaited - logging failure should not block
  fetchAndLog(event).catch(err => {
    console.error('Failed to log event:', err);
  });
}

// Use Promise.allSettled for multiple operations
async function processMultiple(ids: number[]): Promise<User[]> {
  const results = await Promise.allSettled(
    ids.map(id => fetchUser(id))
  );

  const users: User[] = [];
  const errors: Error[] = [];

  for (const result of results) {
    if (result.status === 'fulfilled') {
      users.push(result.value);
    } else {
      errors.push(result.reason);
    }
  }

  if (errors.length > 0) {
    logger.warn(`Failed to fetch ${errors.length} users`, { errors });
  }

  return users;
}
```

