    context = {
        'language': 'python',
        'framework': 'pytest',
        'package_manager': 'uv',
        'project_name': 'MyProject',
        'version': '1.0.0',
        'coverage_targets': {
            'line': 80,
            'branch': 70,
            'function': 90,
            'statement': 85,
            'mutation': 80,
            'path': 60
        }
    }
    print(template.render(**context))
    "
